# =============================================================================
# KNG4 PRST1 — live checklist: copy to .env, fill keys, set POLY_DRY_RUN=false
# =============================================================================
# CLOB signing (required)
POLY_PRIVATE_KEY=0x...
POLY_FUNDER=0x...
POLY_SIGNATURE_TYPE=1
RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

# false = real FAK orders on Polymarket (py_clob_client_v2)
POLY_DRY_RUN=true

# --- PRST1 strategy (defaults match sim sweep + 12c TP) ---
PRST1_POLL_INTERVAL_SECONDS=1.0
PRST1_REQUEST_TIMEOUT_SECONDS=12.0
PRST1_NOTIONAL_USD=1.0
PRST1_OPEN_EDGE=0.065
# TP gate: net $/share after slip model (12c = 0.12)
PRST1_MIN_NET=0.12
PRST1_BAND_LO=0.32
PRST1_BAND_HI=0.68
PRST1_SIGMA_BTC=130
PRST1_SLIP_MODEL=0.008
PRST1_MAX_HOLD_SEC=135
PRST1_COOLDOWN_SEC=2
PRST1_MAX_TRADES_PER_WINDOW=10
PRST1_FORCE_EXIT_BEFORE_END_SECONDS=20
PRST1_NEW_ORDER_CUTOFF_SECONDS=30
# Comma-separated lanes (default: 15m only). Use e.g. 5,15 to run 5m + 15m in parallel.
PRST1_WINDOW_MINUTES=15
# Binance spot + kline open for implied fair (must match PM underlying)
PRST1_BTC_FEED_SYMBOL=BTCUSDT
PRST1_MARKET_SYMBOL=BTC
PRST1_LOG_LEVEL=INFO
