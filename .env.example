# Required for CLOB (same as kng_bot3 / KNG3)
POLY_PRIVATE_KEY=0x...
POLY_FUNDER=0x...
POLY_SIGNATURE_TYPE=1
RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

# Safe default: log signals only
POLY_DRY_RUN=true

# PRST1 parameters (see README)
PRST1_POLL_INTERVAL_SECONDS=1.0
PRST1_NOTIONAL_USD=1.0
PRST1_OPEN_EDGE=0.065
PRST1_MIN_NET=0.065
PRST1_BAND_LO=0.32
PRST1_BAND_HI=0.68
PRST1_SIGMA_BTC=130
PRST1_SLIP_MODEL=0.008
PRST1_MAX_HOLD_SEC=135
# Comma-separated; default 5,15 = simultaneous 5m + 15m BTC up/down
PRST1_WINDOW_MINUTES=5,15
PRST1_MAX_TRADES_PER_WINDOW=10
PRST1_COOLDOWN_SEC=2
PRST1_FORCE_EXIT_BEFORE_END_SECONDS=20
# No new entries when PM window remaining <= this (seconds)
PRST1_NEW_ORDER_CUTOFF_SECONDS=30
# Binance symbol for spot + kline open at window epoch
PRST1_BTC_FEED_SYMBOL=BTCUSDT
PRST1_LOG_LEVEL=INFO
